# Railway Environment Variables
PORT=7860
DEBUG=False
SHEET_NAME=VideoRecapUsers
RAILWAY=true

# Gemini
GEMINI_MODEL=gemini-1.5-flash

# Video Settings
MAX_VIDEO_SIZE_MB=500
MAX_VIDEO_DURATION_MIN=60
FREE_DAILY_LIMIT=2

# Credentials (JSON string - for Railway)
GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_OAUTH_CREDENTIALS_JSON={"web":{"client_id":"...","client_secret":"..."}}
